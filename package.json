{
  "name": "test-insight-hub",
  "version": "0.1.0",
  "description": "Test visualization and feedback tool for developers",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,css}'",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@xyflow/react": "12.10.1",
    "chokidar": "4.0.3",
    "dagre": "0.8.5",
    "html-to-image": "^1.11.11",
    "i18next": "24.2.2",
    "msgpackr": "1.11.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "15.4.1",
    "react-router-dom": "7.13.1",
    "web-tree-sitter": "0.25.3",
    "zod": "3.24.2",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "9.22.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/dagre": "0.7.52",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@vitejs/plugin-react": "4.4.1",
    "@vitest/coverage-v8": "3.1.1",
    "electron": "34.2.0",
    "electron-builder": "25.1.8",
    "electron-vite": "3.1.0",
    "eslint": "9.22.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "husky": "9.1.7",
    "jsdom": "26.0.0",
    "lint-staged": "15.4.3",
    "prettier": "3.5.3",
    "typescript": "5.8.2",
    "typescript-eslint": "8.29.0",
    "v8-to-istanbul": "^9.3.0",
    "vitest": "3.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.test-insight-hub.app",
    "productName": "Test Insight Hub",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "license": "MIT"
}
